# Investor Document Platform — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# --- Portal credentials (fo1.altius.finance) ---
PORTAL_USER=portal_login_email@example.com
PORTAL_PASSWORD=your_portal_password

# --- LLM + embeddings (Gemini) ---
# gemini-2.x: classify / extract / chat. text-embedding-004: pgvector embeddings.
GEMINI_API_KEY=your_gemini_api_key

# --- Database (SQLite per design.md) ---
DATABASE_URL=sqlite:///./data/app.db

# --- Portal (optional overrides) ---
PORTAL_BASE_URL=https://fo1.altius.finance
PORTAL_API_BASE_URL=https://fo1.api.altius.finance
PORTAL_LOGIN_PATH=/login
PORTAL_MAX_LOGIN_RETRIES=3
PORTAL_HEADLESS=true
