%%{init: {"theme":"dark","flowchart":{"htmlLabels":false,"curve":"basis"},"themeVariables":{"fontSize":"14px","fontFamily":"Inter, Helvetica, Arial, sans-serif"}}}%%
flowchart LR
  classDef gilfoyle fill:#1f2937,stroke:#60a5fa,stroke-width:2px,color:#e5e7eb;
  classDef wrapper fill:#0f172a,stroke:#fbbf24,stroke-width:2px,color:#fde68a;
  classDef codex fill:#1f1d2b,stroke:#a78bfa,stroke-width:2px,color:#ddd6fe;
  classDef protected fill:#3f1d1d,stroke:#ef4444,stroke-width:2px,color:#fecaca;
  classDef allowed fill:#102816,stroke:#22c55e,stroke-width:2px,color:#bbf7d0;
  classDef logs fill:#1e293b,stroke:#94a3b8,color:#cbd5e1;
  classDef loop fill:#172554,stroke:#3b82f6,stroke-width:2px,color:#bfdbfe;

  user(["User\nmoriel@xpander.ai"])

  subgraph G ["Gilfoyle (parent agent)"]
    direction TB
    plan["Plan, queue, skills\nworkspace tools only"]
    diff["Reviews diff\nRuns repo validations\nCommits + opens PR"]
  end
  class G,plan,diff gilfoyle

  subgraph LOOP ["Orchestration Loop (per plan item)"]
    direction TB
    pre["Pre-flight\nthink: scope + acceptance\nwrite prompt file\nxpget_agent_plan"]
    fly["In-flight (each checkpoint)\ntail events.jsonl\nthink: progress\nemail milestone if needed"]
    post["Post-flight\nanalyze exit + audit\nxpcomplete_agent_plan_items\nappend queue note\nor replan on failure"]
    pre --> fly --> post
    post -. next plan item .-> pre
  end
  class LOOP,pre,fly,post loop

  subgraph W ["Wrapper bin/codex-run.sh"]
    direction TB
    args["1. Validate args\nREPO + MODE in allowlist\nMODEL in {gpt-5-codex, gpt-5,\n         o4-mini, o3}"]
    env["2. Redact env + identity\nunset GH_*, GITHUB_*, GIT_*\nGIT_CONFIG_GLOBAL=/dev/null\nGIT_CONFIG_SYSTEM=/dev/null\nexport OPENAI_API_KEY only"]
    flags["3. Lock flags\n--cd repo  --sandbox MODE\n--model MODEL\n--ignore-user-config\n--ignore-rules  --ephemeral\n--json  --output-last-message"]
    invoke[["4. codex exec"]]
    audit["5. Post-run audit\nHEAD unchanged?\nfind -newer protected paths\nCross-repo dirty check"]
    usage["6. Distill usage\njq turn.completed.usage\n→ usage.json + ledger.jsonl"]
    invoke --> usage
    usage --> audit
  end
  class W,args,env,flags,invoke,audit wrapper

  subgraph C ["Codex CLI (sub-agent, ephemeral)"]
    direction TB
    cwd["cwd = /agent/data/dev/REPO\nmodel = MODEL"]
    sb["Sandbox: workspace-write\nwritable_roots = empty\nnetwork_access = false"]
    tools["Allowed tools:\nread files in cwd\napply_patch in cwd\nshell within cwd"]
    nogit["FORBIDDEN by prompt + audit:\ngit commit / push / switch -c\ngh CLI / GitHub API\n~/.gitconfig writes"]
  end
  class C,cwd,sb,tools codex
  class nogit protected

  subgraph A ["Allowed targets"]
    repo["/agent/data/dev/REPO/**\nfrontend, xpander-mono,\nxpander-sdk, docs"]
  end
  class A,repo allowed

  subgraph P ["Protected (audited every run)"]
    direction TB
    skills["workspace/dev-knowledge/skills/**"]
    mem["workspace/dev-knowledge/memory/**"]
    ctx["workspace/local/**"]
    ccfg["~/.codex/config.toml\n~/.codex/sessions/**"]
    gh["~/.config/gh/hosts.yml"]
    gc["~/.gitconfig"]
    db[("task_queue\nlocal SQLite")]
  end
  class P,skills,mem,ctx,ccfg,gh,gc,db protected

  subgraph L ["Logs (streamed)"]
    direction TB
    jsonl["events.jsonl"]
    last["last_message.txt"]
    gst["git_status.txt"]
    uj["usage.json\n(input/cached/output tokens)"]
    led["_ledger.jsonl\n(append-only history)"]
  end
  class L,jsonl,last,gst,uj,led logs

  user -->|coding task| plan
  plan --> pre
  fly -. polls .-> jsonl
  fly -. milestone email .-> user
  pre -->|prompt file| args
  args --> env --> flags --> invoke
  invoke -->|stdin: prompt| C
  C -.read or write.-> repo
  C -.blocked by --cd + audit.-> skills
  C -.blocked.-> mem
  C -.blocked.-> ctx
  C -.blocked.-> ccfg
  C -.blocked.-> gh
  C -.blocked.-> gc
  C -.blocked.-> db
  invoke --> jsonl
  invoke --> last
  usage --> uj
  usage --> led
  audit -->|exit 99 on violation| post
  audit -->|exit 0 + git_status.txt| gst
  gst --> post
  post --> diff
  diff -->|commit + push + PR\nas agent identity| repo
